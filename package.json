{
  "name": "altnautica-command",
  "version": "0.8.2",
  "private": false,
  "license": "GPL-3.0-only",
  "description": "Altnautica Command — Open-source Ground Control Station for autonomous drones",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --turbo --port 4000",
    "build": "next build",
    "start": "next start --port 4000",
    "demo": "NEXT_PUBLIC_DEMO_MODE=true next dev --turbo --port 4000",
    "lint": "eslint",
    "cli": "tsx cli/index.ts",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "desktop:dev": "npm run build && npm run electron:compile && electron .",
    "desktop:demo": "npm run build && npm run electron:compile && electron . --demo",
    "desktop:build": "npm run build && npm run electron:compile && electron-builder",
    "desktop:build:mac": "npm run build && npm run electron:compile && electron-builder --mac",
    "desktop:build:win": "npm run build && npm run electron:compile && electron-builder --win",
    "desktop:build:linux": "npm run build && npm run electron:compile && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "test:e2e": "playwright test --project=demo",
    "test:e2e:sitl": "playwright test --project=sitl",
    "test:all": "vitest run && playwright test --project=demo",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy"
  },
  "dependencies": {
    "@blockly/theme-dark": "^8.0.3",
    "@convex-dev/auth": "^0.0.90",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@react-pdf/renderer": "^4.4.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-virtual": "^3.13.22",
    "@xyflow/react": "^12.10.2",
    "blockly": "^12.5.1",
    "cesium": "^1.138.0",
    "convex": "^1.32.0",
    "electron-updater": "^6.0.0",
    "exifr": "^7.1.3",
    "flexsearch": "^0.8.212",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^0.570.0",
    "marked": "^15.0.0",
    "mqtt": "^5.15.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "pako": "^2.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.3",
    "suncalc": "^1.9.0",
    "three": "^0.183.2",
    "uplot": "^1.6.32",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^20",
    "@types/pako": "^2.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "commander": "^13.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "happy-dom": "^20.8.3",
    "listr2": "^8.2.0",
    "msw": "^2.12.10",
    "picocolors": "^1.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "vitest-websocket-mock": "^0.5.0"
  }
}
