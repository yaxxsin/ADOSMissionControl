# ── Altnautica Command — Environment Variables ──────────────
# All variables are optional. Command works standalone with no configuration.
# Use `npm run cli config` to set these interactively.

# ── Local Variables (set here in .env.local) ────────────────

# Demo mode — mock flight engine with 5 simulated drones
# Enabled automatically by `npm run demo`. No need to set manually.
# NEXT_PUBLIC_DEMO_MODE=true

# Number of simulated drones in demo mode (1, 3, 5, or 10)
# NEXT_PUBLIC_DEMO_DRONE_COUNT=5

# Convex backend URL (optional — enables cloud fleet, auth, community features)
# Get from Convex dashboard after creating a deployment at https://convex.dev
# NEXT_PUBLIC_CONVEX_URL=

# GitHub token (optional — raises PX4 releases API from 60 to 5000 req/hr)
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=

# Groq API key (optional — enables AI PID tuning suggestions)
# Free at https://console.groq.com
# GROQ_API_KEY=

# Cesium JS build location (optional — falls back to CDN if not set)
# Only needed if you self-host the Cesium JS library
# CESIUM_BASE_URL=

# ── Convex Server Variables ─────────────────────────────────
# These run inside Convex functions, NOT in Next.js.
# Set them via Convex dashboard (Settings → Environment Variables)
# or CLI: npx convex env set KEY value
#
# CESIUM_ION_TOKEN    — 3D terrain for simulation (free: https://ion.cesium.com)
# GROQ_API_KEY        — AI changelog summaries + PID tuning (free: https://console.groq.com)
# GITHUB_TOKEN        — GitHub API auth for changelog sync (5000 req/hr)
# AI_PID_WEEKLY_LIMIT — Max AI PID analyses per user per week (default: 3)
